# KYS Platform — Environment Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve tüm değerleri doldurun.
# ASLA gerçek değerleri bu dosyaya (.env.example) yazmayın.
# .env dosyası .gitignore'dadır ve commit edilmez.

# ─── ASP.NET Core ───────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development

# ─── PostgreSQL (Docker Compose) ────────────────────────────
DB_USER=kys_user
DB_PASSWORD=changeme_in_production

# ─── JWT Authentication ─────────────────────────────────────
# Üretim: openssl rand -base64 64
JWT_SECRET=

# ─── AES-256-CBC Credential Şifreleme ───────────────────────
# Üretim: ./scripts/generate-secrets.sh
# NOT: Bu anahtarı kaybederseniz şifreli tüm credential'lar okunamaz!
ENCRYPTION_KEY=
ENCRYPTION_IV=

# ─── Production Docker (docker-compose.prod.yml) ────────────
# SSL sertifika dosya yolları (host makinesinde)
SSL_CERT_PATH=/etc/ssl/certs/kys.pem
SSL_KEY_PATH=/etc/ssl/private/kys.key
# JWT ek ayarlar
JWT_ISSUER=kys-api
JWT_AUDIENCE=kys-clients
JWT_EXPIRY_MINUTES=60

# ─── CORS ───────────────────────────────────────────────────
# appsettings.json: Cors:AllowedOrigins
# Geliştirme ortamı için http://localhost:4200 varsayılan olarak tanımlı

# ─── Serilog ────────────────────────────────────────────────
# appsettings.json üzerinden yapılandırılır.
# Seq için (opsiyonel):
# SEQ_URL=http://localhost:5341

# ─── OIDC / Active Directory (Faz 2) ────────────────────────
# Henüz aktif değil — Faz 2'de doldurulacak
# OIDC_AUTHORITY=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
